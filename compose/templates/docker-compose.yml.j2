{#
  Spark Playbook — Phase 0 cluster compose template (PLAN.md §2, §4, §6).

  Rendered by compose/cli.py into compose/rendered/docker-compose.yml.

  NOTE on relative bind-mount paths: docker compose resolves relative volume
  paths against the *compose file's own directory* (compose/rendered/), not the
  invoker's cwd. Two gotchas found and fixed by running this for real:
    - repo bind mount: since this file always renders to compose/rendered/, the
      repo root is two levels up (../../), not one (../) — an earlier ../ mount
      only exposed compose/ inside /workspace.
    - spark-defaults.conf mount: it renders alongside this file in the SAME
      compose/rendered/ directory, so the source is ./spark-defaults.conf, not
      ./rendered/spark-defaults.conf (that path resolved to a nonexistent
      compose/rendered/rendered/... and silently mounted an empty directory,
      which is why spark.master from the conf was never applied and
      spark-submit fell back to local[*]).

  Template variables (defaults live in compose/cli.py, matching PLAN.md §2's table):
    image_name          - built image tag (compose/build.sh's IMAGE_NAME)
    worker_count         - number of spark-worker-N services (default 3, range 1-5)
    worker_cores          - SPARK_WORKER_CORES per worker (default 2, range 1-4)
    worker_memory_gb      - SPARK_WORKER_MEMORY per worker, in GB (default 4, range 1-8)
    driver_memory_gb      - spark.driver.memory, in GB (default 2, fixed) — also used to
                             cap the driver container so it fits the resource budget
    repo_root_container    - absolute path to bind-mount the repo into containers (/workspace)
    public_origin        - deployed instance's public HTTPS origin (docs/architecture/
                            public-deploy.md D4), empty string in dev; forwarded to the
                            driver as SPARKPB_PUBLIC_ORIGIN for driver/jupyter_config.py's
                            CSP frame-ancestors allowlist
    include_kafka         - bool (default false), docs/architecture/kafka-streaming-infra.md
                            D1: render-time flag driven by Topic.requires_kafka, conditionally
                            renders the `kafka` KRaft broker service below, inside this same
                            `sparkpb` project (D2 — load-bearing for the issue-#38 ownership
                            guard and single-slot down/up, which are project-scoped).

  Port surface (docs/architecture/public-deploy.md D2): every published port
  below binds 127.0.0.1 only, never 0.0.0.0 — the internet-facing port surface
  is nginx's 80/443 in the separate deploy/ base stack, not this spawned
  cluster. Master's `6066` (REST submission, unused) and the worker UI ports
  are dropped entirely (worker UIs are reached through the master's own
  reverseProxy, see spark-defaults.conf.j2); the driver's `7078`/`7079`
  (spark.driver.port / blockManager.port) are pinned but no longer published —
  they're intra-cluster only, reached by other containers via Docker DNS.

  Network: dedicated bridge network so `spark://spark-master:7077` resolves by
  container DNS (PLAN.md §1). Compose's default network naming already gives us
  `<project>_default`; we still declare it explicitly for a stable, readable name.
#}
name: sparkpb

networks:
  sparkpb-net:
    driver: bridge

services:
  spark-master:
    image: {{ image_name }}
    container_name: spark-master
    hostname: spark-master
    command: >-
      /opt/spark/bin/spark-class org.apache.spark.deploy.master.Master
      --host spark-master --port 7077 --webui-port 8080
    ports:
      - "127.0.0.1:8080:8080"   # master web UI + /json/ readiness endpoint, loopback only (D2)
      # 6066 (standalone REST submission server, unused; client mode only) is
      # deliberately not published (D2 — drop unused ports from the surface).
      # NOTE: port 7077 (the cluster port) is intentionally NOT published to the
      # host. Only in-network containers dial spark://spark-master:7077, resolved
      # via Docker embedded DNS (PLAN.md §1) — the host never needs to reach it
      # directly. Leaving it unpublished also avoids colliding with any other
      # unrelated Spark stack that may already have host port 7077 bound.
    volumes:
      - ../../:/workspace
      - ./spark-defaults.conf:/opt/spark/conf/spark-defaults.conf:ro
    networks:
      - sparkpb-net
    deploy:
      resources:
        limits:
          cpus: "1"
          memory: 1g
    restart: "no"

{% for i in range(1, worker_count + 1) %}
  spark-worker-{{ i }}:
    image: {{ image_name }}
    container_name: spark-worker-{{ i }}
    hostname: spark-worker-{{ i }}
    command: >-
      /opt/spark/bin/spark-class org.apache.spark.deploy.worker.Worker
      spark://spark-master:7077 --webui-port 8081
    environment:
      # Official apache/spark standalone-worker resource knobs (read by
      # org.apache.spark.deploy.worker.Worker / conf/spark-env.sh conventions):
      SPARK_WORKER_CORES: "{{ worker_cores }}"
      SPARK_WORKER_MEMORY: "{{ worker_memory_gb }}g"
    depends_on:
      - spark-master
    # No host ports published (D2): worker UIs are reached through the
    # master's own reverseProxy (spark.ui.reverseProxy=true in
    # spark-defaults.conf.j2), not by a dedicated host port per worker.
    volumes:
      - ../../:/workspace
      - ./spark-defaults.conf:/opt/spark/conf/spark-defaults.conf:ro
    networks:
      - sparkpb-net
    deploy:
      resources:
        limits:
          cpus: "{{ worker_cores }}"
          memory: {{ worker_memory_gb }}g
    restart: "no"
{% endfor %}

  spark-driver:
    image: {{ image_name }}
    container_name: spark-driver
    hostname: spark-driver
    # PLAN.md §4/US-1.3 fix, found by actually running a notebook cell: unlike
    # `spark-submit`/`pyspark` (which set PYTHONPATH via their own wrapper
    # scripts), a plain JupyterLab kernel process does not get PYTHONPATH for
    # free, so `import pyspark` fails from a notebook cell even though
    # spark-submit-based jobs (compose/smoke_test.py) work fine. Export it
    # (py4j's zip filename resolved via glob, not hardcoded, so it survives a
    # Spark version bump in Dockerfile.spark) before launching Jupyter.
    #
    # PLAN.md §6/R3 fix (issue #7): `--config=` points Jupyter at
    # driver/jupyter_config.py, which sets the CSP `frame-ancestors` header
    # allowing the FastAPI app's origin to embed this server in an iframe
    # (US-1.3) -- without it, the browser's default same-origin framing
    # policy blocks the embed and the iframe renders blank. No extra volume
    # mount is declared for it: the whole repo is already bind-mounted at
    # /workspace below (same reason content/<topic>/notebook.ipynb needs no
    # dedicated mount either), so driver/jupyter_config.py is already visible
    # at /workspace/driver/jupyter_config.py inside the container.
    # `--ServerApp.allow_origin` is intentionally NOT set here anymore (it
    # used to be hardcoded to '*' on this command line) -- jupyter_config.py
    # is now the single source of truth for that setting, scoped to the
    # app's actual origin instead of a wildcard.
    #
    # `--ServerApp.base_url=/jupyter/` + `--ServerApp.allow_remote_access=True`
    # (docs/architecture/public-deploy.md D4): served at a `/jupyter` subpath
    # so nginx can reverse-proxy it alongside the app and the master UI on one
    # domain, and reachable when proxied from a different Host header than
    # `localhost`/`127.0.0.1` (Jupyter's own remote-access guard, distinct
    # from the CSP `frame-ancestors` check in jupyter_config.py). Gated on
    # public_origin (empty in dev): the app's iframe src is built from
    # JUPYTER_URL, which stays the plain `http://localhost:8888` root path in
    # dev (app/config.py) -- forcing base_url=/jupyter/ unconditionally here
    # 404s that iframe, since Jupyter would then only serve under /jupyter/.
    command: >-
      bash -c "export PYTHONPATH=/opt/spark/python:$(ls /opt/spark/python/lib/py4j-*-src.zip):$$PYTHONPATH &&
      /usr/local/bin/jupyter lab
      --config=/workspace/driver/jupyter_config.py
      --ip=0.0.0.0 --port=8888 --no-browser --allow-root
      --ServerApp.token='' --ServerApp.password=''{% if public_origin %} --ServerApp.base_url=/jupyter/ --ServerApp.allow_remote_access=True{% endif %}
      --notebook-dir=/workspace"
    environment:
      # Public deploy (D4): forwarded to jupyter_config.py's CSP
      # frame-ancestors allowlist. Empty string in dev (unchanged behavior).
      SPARKPB_PUBLIC_ORIGIN: "{{ public_origin }}"
    depends_on:
      - spark-master
{% for i in range(1, worker_count + 1) %}
      - spark-worker-{{ i }}
{% endfor %}
    ports:
      - "127.0.0.1:8888:8888"   # JupyterLab, loopback only (D2)
      # PLAN.md §6/R2 names the risk directly, but only mitigated it
      # instructionally ("tell the learner to spark.stop()"), which doesn't
      # actually prevent or detect it. Issue #15 (Phase 2 acceptance
      # validation) reproduced it via ordinary kernel churn: an orphaned
      # kernel whose client connection dropped keeps running server-side,
      # keeping 4040 bound to the OLD application; a second, genuinely-
      # intended session then gets bumped by Spark to 4041 (or 4042). With
      # only 4040 published, that bumped session's UI/REST API became
      # completely unreachable from the host -- while 4040 kept answering
      # confidently for the wrong (old) application the whole time. Publish
      # a small fallback range so a bumped session stays reachable instead
      # of silently vanishing.
      - "127.0.0.1:4040-4042:4040-4042"   # driver application UI + /api/v1/... REST (+ 2 fallback ports), loopback only (D2)
      # spark.driver.port / spark.blockManager.port (pinned, PLAN.md §6/R1)
      # are intentionally NOT published (D2) -- intra-cluster only, reached
      # by other containers via Docker DNS (`spark-driver:7078`/`:7079`).
    volumes:
      - ../../:/workspace
      - ./spark-defaults.conf:/opt/spark/conf/spark-defaults.conf:ro
    networks:
      - sparkpb-net
    deploy:
      resources:
        limits:
          cpus: "2"
          memory: {{ driver_memory_gb }}g
    restart: "no"

{% if include_kafka %}
  kafka:
    image: apache/kafka:3.9.0        # official ASF image, native KRaft; matches apache/spark provenance
    container_name: spark-kafka
    hostname: kafka
    environment:
      KAFKA_NODE_ID: "1"
      KAFKA_PROCESS_ROLES: "broker,controller"
      KAFKA_CONTROLLER_QUORUM_VOTERS: "1@kafka:9093"
      # Two data listeners (D3): PLAINTEXT for in-cluster (advertised as the DNS
      # name kafka:9092), PLAINTEXT_HOST for the loopback host publish (advertised
      # as 127.0.0.1:9092). Distinct in-container ports (9092 vs 29092) are required.
      #
      # DEVIATION FROM THE ADR'S LITERAL YAML: the ADR's draft used an explicit
      # `0.0.0.0:<port>` bind host in KAFKA_LISTENERS. Verified live (docker run
      # apache/kafka:3.9.0) that this exact value makes the native image's
      # KafkaDockerWrapper/StorageTool crash at startup with
      # "IllegalArgumentException: advertised.listeners cannot use the
      # nonroutable meta-address 0.0.0.0" -- reproduced even with a single
      # PLAINTEXT-only listener, so it isn't specific to the dual-listener setup.
      # The official apache/kafka image's own quickstart convention -- an empty
      # host before the port (`://:9092`), which binds all interfaces exactly
      # like `0.0.0.0` does -- boots cleanly (confirmed live) with the same
      # KAFKA_ADVERTISED_LISTENERS/KAFKA_LISTENER_SECURITY_PROTOCOL_MAP as
      # written. Bind-syntax fix only; the two distinct in-container ports and
      # the security-protocol map are unchanged from D3.
      #
      # DEVIATION FROM THE ADR'S LITERAL YAML (second one, R-K6): PLAINTEXT_HOST's
      # advertised address is 127.0.0.1:9092, not localhost:9092 as D3 drafted.
      # Kafka's client protocol is two-hop: after bootstrapping, the client
      # reconnects to whatever address this listener advertises -- so if
      # produce.py's --bootstrap defaults to 127.0.0.1:9092 (the fix for
      # localhost resolving IPv6-first with nothing published on ::1, see
      # produce.py's module docstring) but the broker still hands back
      # "localhost:9092" for the second-hop metadata reconnect, the same
      # IPv6-resolution failure recurs one hop later. Pinning both hops to
      # 127.0.0.1:9092 keeps them consistent.
      KAFKA_LISTENERS: "PLAINTEXT://:9092,PLAINTEXT_HOST://:29092,CONTROLLER://:9093"
      KAFKA_ADVERTISED_LISTENERS: "PLAINTEXT://kafka:9092,PLAINTEXT_HOST://127.0.0.1:9092"
      KAFKA_CONTROLLER_LISTENER_NAMES: "CONTROLLER"
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: "CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT"
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: "1"
      KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR: "1"
      KAFKA_TRANSACTION_STATE_LOG_MIN_ISR: "1"
      KAFKA_AUTO_CREATE_TOPICS_ENABLE: "true"     # producer's first send creates the demo topic
      # DEVIATION FROM THE ADR: not in D3's original block. produce.py's
      # --partitions flag (D5) originally pre-created the topic via
      # KafkaAdminClient to control partition count; verified live that
      # kafka-python(-ng)'s AdminClient controller-discovery
      # (_refresh_controller_id) raises NodeNotReadyError against this
      # single-node KRaft broker (a documented kafka-python limitation, not a
      # config error -- the same client connects and produces successfully
      # via the plain KafkaProducer path). Dropped the admin-client
      # dependency; the broker's own auto-create partition count is set here
      # to match produce.py's DEFAULT_PARTITIONS (3) instead.
      KAFKA_NUM_PARTITIONS: "3"
      KAFKA_HEAP_OPTS: "-Xmx512m -Xms512m"        # bounded heap under the 2GB container limit
      KAFKA_LOG_RETENTION_MINUTES: "10"           # bounded disk (D6)
      KAFKA_LOG_RETENTION_BYTES: "536870912"      # 512MB size cap per partition (D6)
      CLUSTER_ID: "sparkpb-kafka-kraft-0001"      # fixed → deterministic storage format
    ports:
      - "127.0.0.1:9092:29092"   # host 9092 → PLAINTEXT_HOST listener (29092), loopback only (D3)
    networks: [sparkpb-net]
    depends_on: [spark-master]
    deploy:
      resources:
        limits:
          cpus: "1"
          memory: 2g
    restart: "no"
    # No volumes: -- broker data lives in the container's ephemeral writable
    # layer, so `docker compose down` wipes it (D6). No repo mount needed.
{% endif %}
