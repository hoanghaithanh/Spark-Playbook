# Rendered compose/config artifacts (regenerated via compose/cli.py render)
compose/rendered/*
!compose/rendered/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
venv/

# Jupyter
.ipynb_checkpoints/

# Generated data / shared scratch (future phases)
scratch/

# Claude Code local/session state (machine-specific, not shared)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Parallel-session worktrees (each a full checkout; see .claude/worktrees/README.md)
.claude/worktrees/*
!.claude/worktrees/README.md

# Public deploy artifacts (docs/architecture/public-deploy.md, US-PD6) --
# htpasswd, TLS keys/certs, and the domain/email config file are secrets or
# host-specific, never committed.
deploy/secrets/*
!deploy/secrets/.gitkeep
deploy/certs/*
!deploy/certs/.gitkeep
.env
*.env
